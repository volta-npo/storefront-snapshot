    "url": "git+https://github.com/volta-npo/storefront-snapshot.git"
  },
  "homepage": "https://volta-npo.github.io/storefront-snapshot/",
  "bugs": {
    "url": "https://github.com/volta-npo/storefront-snapshot/issues"
  },
  "author": "Volta OSS Division <volta.npo@gmail.com>",
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "typescript": "^6.0.3",
    "@types/node": "^24.0.0"
  }
