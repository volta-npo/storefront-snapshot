{
  "name": "@volta-oss/storefront-snapshot",
  "version": "3.0.0",
  "private": false,
  "type": "module",
  "description": "Before-and-after visual reports for the businesses Volta transforms.",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "npm run build && node --test test/*.test.js",
    "start": "python3 -m http.server 4173",
